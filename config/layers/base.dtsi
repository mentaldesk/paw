// -----------------------------------------------------------------------------------------
// |  Q  |  W  |  F  |  P  |  B  |     |  J  |  L   |  U   |  Y   |  '  |
// |  A  |  R  |  S  |  T  |  G  |     |  M  |  N   |  E   |  I   |  O  | 
// |  X  |  C  |  D  |  V  |  Z  |     |  K  |  H   |  ,   |  .   |  /  |
//             |OSFT |SPC|NAV/DEL|     |BSPC |SPC/FN|OSFT |
base_layer {
    display-name = "Base";
    bindings = <
   &kp Q       &lt WIN W    &kp F        &lt NUM P    &lt BT B         &kp J        &kp L        &lt SWITCH U        &lt MEDIA Y  &kp SQT
   &kp A       &kp R        &kp S        &kp T        &kp G            &kp M        &kp N        &kp E        &kp I        &kp O
   &bml_shft LSHFT X &bml LCTRL C &bml LALT D &bml_no_qt LGUI V  &kp Z            &kp K        &bmr_no_qt RGUI H  &bmr_no_qt RALT COMMA &bmr RCTRL DOT &bmr_shft RSHFT SLASH
                            &osm_meh LC(LA(LSHFT)) LSHFT  &lt BRAC SPACE &lt_qt NAV DEL      &lt_qt FUNC BSPC &lt SYM SPACE &osm_meh LC(LA(LSHFT)) RSHFT
    >;
};
